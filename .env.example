# Supabase (públicas — prefijo NEXT_PUBLIC)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Supabase service role — SOLO en servidor, nunca en el cliente
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Email con Resend (opcional — para notificaciones de leads)
RESEND_API_KEY=re_YOUR_KEY
RESEND_FROM_EMAIL=noreply@ingenieriacantabria.com
NOTIFICATION_EMAIL=info@ingenieriacantabria.com

# Site
NEXT_PUBLIC_SITE_URL=https://www.ingenieriacantabria.com
